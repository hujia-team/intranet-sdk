# Intranet SDK 配置示例
# 复制此文件为 .env 并填入实际的凭证信息

# STS 认证凭证（推荐）
INTRANET_ACCESS_KEY_ID=your_access_key_id
INTRANET_ACCESS_KEY_SECRET=your_access_key_secret

# API 基础 URL（可选，默认为下面的值）
# INTRANET_BASE_URL=https://intranet.minieye.tech/sys-api

# Artifact 集成测试 / 手工联调参数
# INTRANET_ARTIFACT_NAME=vision-demo-artifact
# INTRANET_ARTIFACT_MODULE_PATH=adas/vision
# INTRANET_ARTIFACT_TYPE=pkg
# INTRANET_ARTIFACT_SEMANTIC_VERSION=1.2.3
# INTRANET_ARTIFACT_INCLUDE_VIRTUAL=false
# INTRANET_ARTIFACT_DOWNLOAD_TYPE=artifact
# INTRANET_ARTIFACT_DOWNLOAD=false
# INTRANET_ARTIFACT_DOWNLOAD_DIR=./downloads
# INTRANET_ARTIFACT_VERIFY_HASH=true
# INTRANET_ARTIFACT_SKIP_EXISTING=true
# INTRANET_ARTIFACT_DOWNLOAD_MAX_RETRIES=2
# INTRANET_ARTIFACT_DOWNLOAD_RETRY_DELAY=1.0
# INTRANET_ARTIFACT_UPDATE_TAGS=false
# INTRANET_ARTIFACT_PATCH_TAGS=false
# INTRANET_ARTIFACT_TAG_SCHEMA_VERSION=0.2.0
# 全量更新 tags 时使用（需要满足完整 schema）
# INTRANET_ARTIFACT_TAGS_JSON={"schema_version":"0.2.0","decision":"pass","decision_basis":{"compare_result":"optimized"}}
# 局部更新 tags 时使用
# INTRANET_ARTIFACT_TAGS_PATCH_JSON={"decision":"pass","decision_basis":{"compare_result":"optimized"}}
